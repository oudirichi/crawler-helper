{
  "name": "crawler-helper",
  "version": "0.0.2",
  "description": "Crawler helper",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "",
    "lint": "eslint src/"
  },
  "keywords": [
    "typescript",
    "library"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.5",
    "eslint": "^10.0.2",
    "tsdown": "^0.2.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.56.1"
  },
  "sideEffects": false,
  "dependencies": {
    "env-paths": "^4.0.0",
    "puppeteer-core": "^24.37.5"
  }
}
